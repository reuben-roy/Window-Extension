generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdeaStatus {
  queued
  syncing
  running
  completed
  failed
  kept
  discarded
}

enum OpenClawSessionStatus {
  active
  idle
  closed
}

enum OpenClawJobStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum AssistantConnectorType {
  openclaw
}

enum AssistantTaskStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum TaskNotificationMode {
  immediate
  after_focus
  inbox_only
}

enum AssistantFocusContextType {
  none
  window_task
  calendar_event
}

enum RecommendationKind {
  focus
  calendar
  interest
  automation
}

enum AuthProvider {
  google
  github
  password
}

model User {
  id               String             @id @default(cuid())
  supabaseUserId   String?            @unique
  email            String?            @unique
  displayName      String?
  avatarUrl        String?
  selectedConnectorId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  authCodes        AuthCode[]
  identities       AuthIdentity[]
  syncState        UserSyncState?
  backendSessions  BackendSession[]
  ideaCaptures     IdeaCapture[]
  openClawSessions OpenClawSession[]
  assistantTasks   AssistantTask[]
  breakVisitEvents BreakVisitEvent[]
  taskTags         TaskTag[]
  focusSessions    FocusSession[]
  activitySessions ActivitySession[]
  dailyAnalytics   DailyAnalyticsAggregate[]
  analyticsOverrides AnalyticsOverride[]
  interestProfiles InterestProfile[]
  recommendations  Recommendation[]
  selectedConnector OpenClawConnection? @relation("SelectedConnector", fields: [selectedConnectorId], references: [id], onDelete: SetNull)
}

model AuthIdentity {
  id            String       @id @default(cuid())
  userId        String
  provider      AuthProvider
  providerUserId String
  email         String?
  emailVerified Boolean      @default(false)
  passwordHash  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([email])
}

model AuthCode {
  id        String       @id @default(cuid())
  userId    String
  provider  AuthProvider
  codeHash  String       @unique
  expiresAt DateTime
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSyncState {
  id        String   @id @default(cuid())
  userId    String   @unique
  revision  Int
  snapshot  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackendSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpenClawConnection {
  id          String                @id @default(cuid())
  key         String                @unique
  name        String
  connectorType AssistantConnectorType @default(openclaw)
  transport   String
  host        String?
  baseUrl     String?
  description String?
  enabled     Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  sessions    OpenClawSession[]
  assistantTasks AssistantTask[]
  selectedByUsers User[]            @relation("SelectedConnector")
}

model OpenClawSession {
  id             String                @id @default(cuid())
  userId         String
  connectorId    String?
  remoteSessionId String?
  title          String
  status         OpenClawSessionStatus @default(active)
  modelLabel     String?
  startedAt      DateTime              @default(now())
  lastActivityAt DateTime              @default(now())
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  connector      OpenClawConnection?   @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  ideaCaptures   IdeaCapture[]
  assistantTasks AssistantTask[]

  @@unique([connectorId, remoteSessionId])
}

model IdeaCapture {
  id            String      @id @default(cuid())
  userId        String
  clientLocalId String
  prompt        String
  preferredModel String?
  assistantNotes String?
  status        IdeaStatus  @default(queued)
  saved         Boolean     @default(false)
  archived      Boolean     @default(false)
  lastError     String?
  sessionId     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       OpenClawSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  researchJob   ResearchJob?
  report        IdeaReport?

  @@unique([userId, clientLocalId])
}

model ResearchJob {
  id          String            @id @default(cuid())
  ideaId       String            @unique
  remoteJobId  String?           @unique
  status       OpenClawJobStatus @default(queued)
  title        String
  lastError    String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  idea         IdeaCapture       @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model IdeaReport {
  id                  String      @id @default(cuid())
  ideaId               String      @unique
  summary             String
  viability           String
  competitionSnapshot String
  buildEffort         String
  revenuePotential    String
  risks               Json
  nextSteps           Json
  sourceLinks         Json
  completedAt         DateTime
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  idea                IdeaCapture @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model AssistantTask {
  id               String                   @id @default(cuid())
  userId           String
  connectorId      String?
  prompt           String
  title            String
  preferredModel   String?
  assistantNotes   String?
  status           AssistantTaskStatus      @default(queued)
  notificationMode TaskNotificationMode     @default(after_focus)
  focusContextType AssistantFocusContextType @default(none)
  focusContextId   String?
  lastError        String?
  sessionId        String?
  notifiedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  connector        OpenClawConnection?      @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  session          OpenClawSession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  job              AssistantTaskJob?
  result           AssistantTaskResult?
}

model AssistantTaskJob {
  id          String              @id @default(cuid())
  taskId       String              @unique
  remoteJobId  String?
  status       AssistantTaskStatus @default(queued)
  lastError    String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  task         AssistantTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AssistantTaskResult {
  id          String         @id @default(cuid())
  taskId      String         @unique
  summary     String
  output      String
  completedAt DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  task        AssistantTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model BreakVisitEvent {
  id               String   @id @default(cuid())
  userId           String
  tabId            Int?
  domain           String
  activeEventTitle String?
  startedAt        DateTime
  endedAt          DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestProfile {
  id          String   @id @default(cuid())
  userId      String
  key         String
  label       String
  proficiency Int      @default(0)
  minutes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model Recommendation {
  id        String             @id @default(cuid())
  userId    String
  kind      RecommendationKind
  title     String
  body      String
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskTag {
  id                 String   @id @default(cuid())
  userId             String
  key                String
  label              String
  color              String
  aliases            Json
  baselineDifficulty Int
  alignedDomains     Json
  supportiveDomains  Json
  source             String
  archivedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, updatedAt])
}

model FocusSession {
  id                String   @id @default(cuid())
  userId            String
  clientSessionId   String
  calendarEventId   String
  eventTitle        String
  scheduledStart    DateTime
  scheduledEnd      DateTime
  startedAt         DateTime
  endedAt           DateTime
  sourceRuleType    String
  sourceRuleName    String?
  tagKey            String?
  secondaryTagKeys  Json
  difficultyRank    Int?
  productiveMinutes Int      @default(0)
  supportiveMinutes Int      @default(0)
  distractedMinutes Int      @default(0)
  awayMinutes       Int      @default(0)
  breakMinutes      Int      @default(0)
  totalTrackedMinutes Int    @default(0)
  leftEarly         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activitySessions  ActivitySession[]
  analyticsOverride AnalyticsOverride?

  @@unique([userId, clientSessionId])
  @@index([userId, startedAt])
  @@index([userId, tagKey, startedAt])
}

model ActivitySession {
  id              String   @id @default(cuid())
  userId          String
  clientActivityId String
  focusSessionId  String
  calendarEventId String
  eventTitle      String
  domain          String?
  startedAt       DateTime
  endedAt         DateTime
  activityClass   String
  tagKey          String?
  secondaryTagKeys Json
  difficultyRank  Int?
  sourceRuleType  String
  sourceRuleName  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSession    FocusSession @relation(fields: [focusSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, clientActivityId])
  @@index([userId, startedAt])
  @@index([focusSessionId, startedAt])
}

model DailyAnalyticsAggregate {
  id                String   @id @default(cuid())
  userId            String
  day               DateTime
  productiveMinutes Int      @default(0)
  supportiveMinutes Int      @default(0)
  distractedMinutes Int      @default(0)
  awayMinutes       Int      @default(0)
  breakMinutes      Int      @default(0)
  totalFocusSessions Int     @default(0)
  leftEarlyCount    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId, day])
}

model AnalyticsOverride {
  id             String   @id @default(cuid())
  userId         String
  focusSessionId String   @unique
  tagKey         String?
  difficultyRank Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSession   FocusSession @relation(fields: [focusSessionId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}
